<?xml version="1.0" encoding="UTF-8"?>
<solver xmlns="https://timefold.ai/xsd/solver">
  <solutionClass>com.stock.stock.planning.StockRedistributionSolution</solutionClass>
  <entityClass>com.stock.stock.planning.Transfer</entityClass>
  <scoreDirectorFactory>
    <constraintProviderClass>com.stock.stock.planning.StockConstraintProvider</constraintProviderClass>
  </scoreDirectorFactory>
  <!-- Terminare foarte rapidă: max 2s; oprire după 0.5s fără îmbunătățire -->
  <termination>
    <spentLimit>2s</spentLimit>
    <unimprovedSpentLimit>500ms</unimprovedSpentLimit>
  </termination>
</solver>
